{"nodes": [{"id": "readme_airgap_guardian", "label": "Airgap Guardian", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Offline-first security tool for air-gapped environments: a single CLI executable requiring no network access, so it can run where connectivity is deliberately absent."}, {"id": "readme_cert_scanner", "label": "Certificate Scanner (cert)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scans X.509 certificates (PEM/DER auto-detected) for expiration and security issues; unparseable files become parse errors instead of aborting the scan."}, {"id": "readme_ssh_scanner", "label": "SSH Scanner", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses format heuristics (OpenSSH cipher name, PEM Proc-Type headers) rather than decryption to detect passphrase protection, keeping the scan offline and passive."}, {"id": "readme_secrets_scanner", "label": "Secrets Scanner", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Conservative regex rules to limit false positives; binary files and files over 1 MiB skipped for performance; previews redacted so secrets are never printed in full."}, {"id": "readme_jwt_scanner", "label": "JWT Scanner", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Analyzes structure and claims (alg, exp, iss, aud) without signature verification, since key material is unavailable offline; non-JSON candidates silently ignored to avoid noise."}, {"id": "readme_policy_engine", "label": "Policy Engine", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All thresholds resolved from one policy loaded and validated before scanning, so a report can always be interpreted from its embedded policy alone; unknown TOML fields are rejected to catch typos; invalid policies fail fast with exit code 7."}, {"id": "readme_risk_score", "label": "Risk Score", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Additive 0-100 score from expiration status and findings, capped at 100, giving a single comparable severity number across certificates and assets."}, {"id": "readme_html_report", "label": "HTML Report", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Standalone single file with embedded CSS, no JavaScript, no external assets so it renders fully offline; the active policy is embedded so reports remain interpretable later without the original policy file."}, {"id": "readme_json_output", "label": "JSON Output", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Confirmation messages go to stderr so JSON on stdout stays clean and pipeable; every entry carries an asset_type and the effective policy is embedded in the output."}, {"id": "readme_scan_command", "label": "scan Command", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Takes exactly one input (positional directory or --inventory); --scanners cannot combine with --inventory because the inventory specifies scanners per target."}, {"id": "readme_discover_command", "label": "discover Command", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Metadata-first classification (file names, extensions, directory names) instead of full analysis so large trees can be surveyed quickly; only small text files are probed for JWT structures."}, {"id": "readme_inventory_command", "label": "inventory Command", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Catalogs every discovered asset with complete details rather than reporting findings; exits 0 regardless of findings because cataloging is not a pass/fail check."}, {"id": "readme_inventory_file", "label": "Inventory File (inventory.toml)", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Versioned TOML with [[scan]] entries; duplicate paths merged and scanner lists combined so each unique directory is walked exactly once; strict validation (exit code 7) reports all violations in a single message."}, {"id": "readme_exit_codes", "label": "Exit Codes", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "scan returns the highest severity encountered (0-3) so scripts can gate on results; 4-7 are reserved for usage, missing directory, runtime, and policy/inventory errors."}, {"id": "readme_expiration_status", "label": "Expiration Status", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_security_checks", "label": "Security Check Rules", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Findings are reported separately from expiration status; asset checks reuse the same policy thresholds as certificate checks for consistency."}, {"id": "readme_single_directory_walk", "label": "Single Shared Directory Walk", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All scanners share one directory walk; each file is read at most once and offered to every scanner that can process it; a failure in one file or scanner never aborts the scan \u2014 performance plus resilience."}], "edges": [{"source": "readme_scan_command", "target": "readme_cert_scanner", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_scan_command", "target": "readme_ssh_scanner", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_scan_command", "target": "readme_secrets_scanner", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_scan_command", "target": "readme_jwt_scanner", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_airgap_guardian", "target": "readme_scan_command", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_airgap_guardian", "target": "readme_discover_command", "relation": "references", "confidence": "EXTRACTED", 